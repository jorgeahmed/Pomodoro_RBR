# Environment Variables — copy this to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://rdmywbcfcubiutcqnwjl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Resend (email sending) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Gemini AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── Server ────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://jorgeahmed.github.io/Pomodoro_RBR/app.html
API_URL=https://syncro-daily-api.up.railway.app

# ── Todoist OAuth App ─────────────────────────────────────────────
# Register at: https://todoist.com/prefs/integrations → Create App
# Redirect URI: https://syncro-daily-api.up.railway.app/api/oauth/todoist/callback
TODOIST_CLIENT_ID=your_todoist_client_id
TODOIST_CLIENT_SECRET=your_todoist_client_secret

# ── Asana OAuth App ───────────────────────────────────────────────
# Register at: https://app.asana.com/0/my-apps → Create new app
# Redirect URI: https://syncro-daily-api.up.railway.app/api/oauth/asana/callback
ASANA_CLIENT_ID=your_asana_client_id
ASANA_CLIENT_SECRET=your_asana_client_secret

# ── Monday OAuth App ──────────────────────────────────────────────
# Register at: https://monday.com/settings/apps/new
# Redirect URI: https://syncro-daily-api.up.railway.app/api/oauth/monday/callback
MONDAY_CLIENT_ID=your_monday_client_id
MONDAY_CLIENT_SECRET=your_monday_client_secret

# ── ClickUp OAuth App ─────────────────────────────────────────────
# Register at: https://app.clickup.com/settings/apps
# Redirect URI: https://syncro-daily-api.up.railway.app/api/oauth/clickup/callback
CLICKUP_CLIENT_ID=your_clickup_client_id
CLICKUP_CLIENT_SECRET=your_clickup_client_secret

# ── Jira OAuth App ────────────────────────────────────────────────
# Register at: https://developer.atlassian.com/console/myapps/
# Redirect URI: https://syncro-daily-api.up.railway.app/api/oauth/jira/callback
JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret
